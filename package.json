{
    "name": "babel-discord-translator",
    "version": "1.0.0",
    "description": "Discord right-click translation bot powered by Vertex AI Gemini — with LRU cache, cost tracking, multilingual support, and web dashboard",
    "type": "module",
    "main": "src/index.ts",
    "scripts": {
        "start": "node --import tsx src/index.ts",
        "dev": "node --import tsx --watch src/index.ts",
        "build": "tsc && cp -r src/locales dist/src/locales && cp -r src/public dist/src/public",
        "typecheck": "tsc --noEmit",
        "register": "node --import tsx scripts/register.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint src/ tests/",
        "format": "prettier --write ."
    },
    "keywords": [
        "discord",
        "translation",
        "bot",
        "gemini",
        "vertex-ai",
        "discord.js",
        "multilingual"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/0xH4KU/babel-discord-translator"
    },
    "dependencies": {
        "discord.js": "^14.18.0",
        "dotenv": "^16.4.0",
        "express": "^4.21.0",
        "express-rate-limit": "^8.3.1"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/node": "^25.5.0",
        "eslint": "^9.0.0",
        "globals": "^15.0.0",
        "prettier": "^3.0.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.0",
        "vitest": "^3.0.0"
    }
}
