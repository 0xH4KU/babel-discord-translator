{
    "name": "babel-discord-translator",
    "version": "1.0.0",
    "description": "Discord right-click translation bot powered by Vertex AI Gemini — with LRU cache, cost tracking, multilingual support, and web dashboard",
    "type": "module",
    "main": "src/index.js",
    "scripts": {
        "start": "node src/index.js",
        "dev": "node --watch src/index.js",
        "register": "node scripts/register.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint src/ tests/",
        "format": "prettier --write ."
    },
    "keywords": [
        "discord",
        "translation",
        "bot",
        "gemini",
        "vertex-ai",
        "discord.js",
        "multilingual"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/0xH4KU/babel-discord-translator"
    },
    "dependencies": {
        "discord.js": "^14.18.0",
        "dotenv": "^16.4.0",
        "express": "^4.21.0",
        "express-rate-limit": "^8.3.1"
    },
    "devDependencies": {
        "eslint": "^9.0.0",
        "globals": "^15.0.0",
        "prettier": "^3.0.0",
        "vitest": "^3.0.0"
    }
}
